# Server Configuration
PORT=3000
NODE_ENV=development

# Browser Pool Configuration
BROWSER_POOL_SIZE=5
BROWSER_HEADLESS=true
BROWSER_TIMEOUT=30000

# Redis Configuration
REDIS_URL=redis://localhost:6379
CACHE_TTL=3600

# Rate Limiting Configuration
RATE_LIMIT_WINDOW=900000
RATE_LIMIT_MAX=100

# Proxy Configuration
PROXY_LIST=
PROXY_ROTATION=false

# Logging Configuration
LOG_LEVEL=info
LOG_FORMAT=json

# Webhook Configuration
WEBHOOK_TIMEOUT=10000
WEBHOOK_RETRIES=3

# Security
API_KEYS=

# Python AI Server
PYTHON_SERVER_URL=http://localhost:5001

# Feature Flags (default: true)
# Set false on VPS to disable heavy modules without removing code.
FEATURE_IMAGE_AI=true
FEATURE_AUDIO_AI=true
FEATURE_CHAT_AI=true
FEATURE_VIDEO_DL=true

# AIOS WhatsApp Gateway
# Backend de LLM: codex (default) ou claude
AIOS_LLM_BACKEND=codex

# Codex CLI (recomendado)
CODEX_CLI_PATH=codex
AIOS_PROJECT_PATH=

# Claude CLI (fallback opcional)
ANTHROPIC_API_KEY=
CLAUDE_CLI_PATH=/usr/local/bin/claude

# Evolution API (obrigatório para resposta no WhatsApp)
EVOLUTION_API_BASE_URL=
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE=
